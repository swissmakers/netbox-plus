# Copy to project root as `.env` for podman compose:
#   cp docker/.env.example .env

# Required: at least 50 random characters for production
NETBOX_SECRET_KEY=change-me-to-a-long-random-string-at-least-fifty-characters-long

# Optional: v2 API token pepper (50+ chars). If unset, a pepper is derived from NETBOX_SECRET_KEY.
# NETBOX_API_TOKEN_PEPPER_1=

# Database (defaults match docker-compose postgres service)
POSTGRES_USER=netbox
POSTGRES_PASSWORD=netbox
POSTGRES_DB=netbox

# first-time superuser (set NETBOX_CREATE_SUPERUSER=1)
NETBOX_CREATE_SUPERUSER=1
NETBOX_SUPERUSER_NAME=admin
NETBOX_SUPERUSER_EMAIL=admin@swissmakers.ch
NETBOX_SUPERUSER_PASSWORD=swissmakers

# Host header / CSRF (comma-separated). Include the URL you use in the browser.
NETBOX_ALLOWED_HOSTS=*
NETBOX_CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Serve /static/ from Gunicorn (collectstatic output). Set to 0 if you terminate TLS and serve static with nginx.
# NETBOX_SERVE_STATIC=1

# Publish port on the host
NETBOX_PUBLISH_PORT=8080

# Django DEBUG (never enable in production). Compose passes NETBOX_DEBUG to the web container.
# NETBOX_DEBUG=true

# NetBox app image: default swissmakers/netbox-plus:latest.
# For local builds, set NETBOX_IMAGE=localhost/netbox-plus:dev after running:
#   podman build -t netbox-plus:dev .
#   NETBOX_IMAGE=registry.example.com/netbox/netbox-plus:1.2.3

# Optional: for local podman build on x86-64-v3-capable hosts only:
#   NETBOX_BASE_IMAGE=registry.access.redhat.com/ubi10/ubi:latest
